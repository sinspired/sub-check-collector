# GitHub Personal Access Token (可选,但强烈建议配置)
# 获取方式: https://github.com/settings/tokens
# 需要权限: public_repo
# 配置后 API 限额从 60次/小时 提升到 5000次/小时
GITHUB_TOKEN=your_github_token_here

# 搜索关键字 (逗号分隔，用于关键词搜索策略)
SEARCH_KEYWORDS=free,v2ray,subscription,vless

# 多组搜索关键词 (可选，| 分隔各组，, 分隔组内关键词)
# 不配置则使用默认 7 组关键词
# KEYWORD_GROUPS=free,v2ray,subscription|vmess,free,nodes|clash,proxy,subscription

# 定时执行规则 (cron 表达式)
# 示例:
#   0 2 * * *     - 每天凌晨 2 点
#   0 */6 * * *   - 每 6 小时
#   0 0 * * 0     - 每周日凌晨
SCHEDULE_INTERVAL=0 2 * * *

# 输出文件路径
OUTPUT_FILE=./output/subscriptions.md

# 最大搜索仓库数
MAX_REPOSITORIES=50

# config.yaml 文件路径 (自动更新订阅链接)
CONFIG_YAML_PATH=./config.yaml

# 最低 star 数量 (0 表示不限制)
MIN_STARS=0

# 仓库最大更新天数 (超过此天数未提交代码的仓库将被忽略)
# 会用 GitHub API 检查实际最后提交时间，而非仓库活动时间（star/fork 等）
# 推荐值: 30-90 天
MAX_DAYS_SINCE_UPDATE=60

# 代理地址 (用于链接验证等网络请求)
# 如 Clash 默认端口: http://127.0.0.1:7890
# 留空则直连
PROXY_URL=http://127.0.0.1:7890

# 订阅文件最大更新天数 (文件级过滤)
# 对 raw.githubusercontent.com 链接用 GitHub API 检查文件最后提交时间
# 对其他链接用 HTTP Last-Modified 头检查
# 超过此天数未更新的订阅链接将被过滤
MAX_DAYS_SINCE_SUB_UPDATE=3

# 是否遍历仓库根目录查找订阅文件 (true/false)
# 开启后会额外读取仓库中的 .txt/.yaml/.json 等订阅文件
# 关闭则只读取 README
EXPLORE_FILE_TREE=false

# 是否验证链接有效性 (true/false)
# 开启后会检测每个订阅链接是否可访问,过滤掉无效链接
# 同时检查文件新鲜度（Last-Modified / GitHub API）
VALIDATE_LINKS=true

# 链接验证超时时间 (毫秒)
# 默认 10 秒,超过此时间未响应的链接将被视为无效
LINK_VALIDATION_TIMEOUT=10000

# 链接验证并发数
# 默认 10,同时验证的链接数量,建议根据网络情况调整
# 值越大验证越快,但可能触发服务器限流
LINK_VALIDATION_CONCURRENCY=50

# 日志目录
LOG_DIR=./logs

# 是否启用文件日志 (true/false)
# 设置为 false 则仅在控制台输出日志
ENABLE_FILE_LOG=true
